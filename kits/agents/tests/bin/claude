#!/usr/bin/env bash
# Mock Claude CLI — used by kits/agents/tests/ to avoid launching a real worker.
#
# Behaviour selector: MOCK_CLAUDE_MODE env var
#   happy          (default) — exit 0, emit realistic stream-json response
#   timeout        — exit 1, "timed out" on stderr, no stdout JSON
#   error          — exit 0, stream-json with is_error=true
#   slow           — sleeps 10s before emitting anything (for time_limit tests)
#   budget_exceeded — emits an assistant event reporting 5M tokens then sleeps
#                    (dispatcher kills it once it reads the token count)
#   commit_to_scope — writes a file into $MOCK_COMMIT_DIR and runs git add +
#                    git commit there, then emits happy-path JSON. Used to prove
#                    that a worker can commit to an outer repo when scope is a
#                    non-git subdir with no worktree isolation.
#   commit_to_add_dir — parses its own argv for the --add-dir value and commits
#                    there. Used to verify post-fix isolation: the commit must
#                    land on the worktree branch, not on the outer repo's HEAD.
#
# If MOCK_CLAUDE_ARGS_FILE is set, all received args are appended there
# so tests can assert which flags the spawner passed.

set -u

if [[ -n "${MOCK_CLAUDE_ARGS_FILE:-}" ]]; then
    echo "$@" >> "$MOCK_CLAUDE_ARGS_FILE"
fi

MODE="${MOCK_CLAUDE_MODE:-happy}"

case "$MODE" in
    happy)
        printf '{"type":"assistant","message":{"id":"msg_mock","type":"message","role":"assistant","content":[],"model":"claude-sonnet-4-6","usage":{"input_tokens":1234,"output_tokens":567,"cache_creation_input_tokens":0,"cache_read_input_tokens":890}},"session_id":"mock"}\n'
        printf '{"type":"result","subtype":"success","is_error":false,"duration_ms":1000,"duration_api_ms":900,"num_turns":5,"result":"Mock worker completed task successfully.","session_id":"mock","total_cost_usd":0.0,"usage":{"input_tokens":1234,"output_tokens":567,"cache_creation_input_tokens":0,"cache_read_input_tokens":890},"permission_denials":[]}\n'
        exit 0
        ;;
    timeout)
        echo "Gateway agent failed: LLM request timed out. (timeout)" >&2
        exit 1
        ;;
    error)
        printf '{"type":"assistant","message":{"id":"msg_mock","type":"message","role":"assistant","content":[],"model":"claude-sonnet-4-6","usage":{"input_tokens":100,"output_tokens":10,"cache_creation_input_tokens":0,"cache_read_input_tokens":0}},"session_id":"mock"}\n'
        printf '{"type":"result","subtype":"error_during_execution","is_error":true,"duration_ms":100,"duration_api_ms":100,"num_turns":1,"result":"Mock error occurred during task execution.","session_id":"mock","total_cost_usd":0.0,"usage":{"input_tokens":100,"output_tokens":10,"cache_creation_input_tokens":0,"cache_read_input_tokens":0},"permission_denials":[]}\n'
        exit 0
        ;;
    slow)
        sleep 10
        ;;
    budget_exceeded)
        # Report 5M input tokens in the first assistant event — any sane budget
        # cap will be exceeded on reading this. The dispatcher sends SIGTERM and
        # we never reach the sleep below.
        printf '{"type":"assistant","message":{"id":"msg_mock","type":"message","role":"assistant","content":[],"model":"claude-sonnet-4-6","usage":{"input_tokens":5000000,"output_tokens":0,"cache_creation_input_tokens":0,"cache_read_input_tokens":0}},"session_id":"mock"}\n'
        sleep 10
        ;;
    commit_to_scope)
        # Prove the scope-escape attack: write a file into MOCK_COMMIT_DIR (a
        # non-git subdir inside an outer git repo) and commit. git traverses
        # parent dirs to find .git, so the commit lands on the outer repo's
        # current branch. If this succeeds the vulnerability is real.
        dir="${MOCK_COMMIT_DIR:?MOCK_COMMIT_DIR must be set for commit_to_scope mode}"
        echo "scope-escape-content" > "$dir/scope-escape.txt"
        git -C "$dir" add scope-escape.txt
        git -C "$dir" commit -m "scope-escape-commit"
        printf '{"type":"assistant","message":{"id":"msg_mock","type":"message","role":"assistant","content":[],"model":"claude-sonnet-4-6","usage":{"input_tokens":100,"output_tokens":10,"cache_creation_input_tokens":0,"cache_read_input_tokens":0}},"session_id":"mock"}\n'
        printf '{"type":"result","subtype":"success","is_error":false,"duration_ms":100,"duration_api_ms":100,"num_turns":1,"result":"Committed to scope dir.","session_id":"mock","total_cost_usd":0.0,"usage":{"input_tokens":100,"output_tokens":10,"cache_creation_input_tokens":0,"cache_read_input_tokens":0},"permission_denials":[]}\n'
        exit 0
        ;;
    commit_to_add_dir)
        # Post-fix isolation check: commit to the directory the dispatcher
        # actually passed via --add-dir, which after the fix is the worktree
        # subdir rather than the original outer-repo path. The commit lands
        # on the worktree branch, not on the outer repo's HEAD.
        commit_dir=""
        prev_arg=""
        for arg in "$@"; do
            if [[ "$prev_arg" == "--add-dir" ]]; then
                commit_dir="$arg"
                break
            fi
            prev_arg="$arg"
        done
        if [[ -z "$commit_dir" ]]; then
            echo "commit_to_add_dir: no --add-dir arg found in argv" >&2
            exit 2
        fi
        mkdir -p "$commit_dir"
        echo "scope-escape-content" > "$commit_dir/scope-escape.txt"
        git -C "$commit_dir" add scope-escape.txt
        git -C "$commit_dir" \
            -c user.email=mock@test.local \
            -c user.name="Mock Worker" \
            commit -m "scope-escape-commit"
        printf '{"type":"assistant","message":{"id":"msg_mock","type":"message","role":"assistant","content":[],"model":"claude-sonnet-4-6","usage":{"input_tokens":100,"output_tokens":10,"cache_creation_input_tokens":0,"cache_read_input_tokens":0}},"session_id":"mock"}\n'
        printf '{"type":"result","subtype":"success","is_error":false,"duration_ms":100,"duration_api_ms":100,"num_turns":1,"result":"Committed to add-dir scope.","session_id":"mock","total_cost_usd":0.0,"usage":{"input_tokens":100,"output_tokens":10,"cache_creation_input_tokens":0,"cache_read_input_tokens":0},"permission_denials":[]}\n'
        exit 0
        ;;
    *)
        echo "mock claude: unknown MOCK_CLAUDE_MODE='$MODE' (expected happy|timeout|error|slow|budget_exceeded|commit_to_scope|commit_to_add_dir)" >&2
        exit 2
        ;;
esac
