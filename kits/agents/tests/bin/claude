#!/usr/bin/env bash
# Mock Claude CLI — used by kits/agents/tests/ to avoid launching a real worker.
#
# Behaviour selector: MOCK_CLAUDE_MODE env var
#   happy   (default) — exit 0, emit realistic JSON response on stdout
#   timeout           — exit 1, "timed out" on stderr, no stdout JSON
#   error             — exit 1, JSON with is_error=true on stdout
#
# If MOCK_CLAUDE_ARGS_FILE is set, all received args are appended there
# so tests can assert which flags the spawner passed.

set -u

if [[ -n "${MOCK_CLAUDE_ARGS_FILE:-}" ]]; then
    echo "$@" >> "$MOCK_CLAUDE_ARGS_FILE"
fi

MODE="${MOCK_CLAUDE_MODE:-happy}"

case "$MODE" in
    happy)
        echo '{"result":"Mock worker completed task successfully.","usage":{"input_tokens":1234,"output_tokens":567,"cache_read_input_tokens":890},"num_turns":5,"permission_denials":[],"stop_reason":"end_turn","is_error":false,"total_cost_usd":0.0}'
        exit 0
        ;;
    timeout)
        echo "Gateway agent failed: LLM request timed out. (timeout)" >&2
        exit 1
        ;;
    error)
        echo '{"result":"Mock error occurred during task execution.","usage":{"input_tokens":100,"output_tokens":10,"cache_read_input_tokens":0},"num_turns":1,"permission_denials":[],"stop_reason":"error","is_error":true,"total_cost_usd":0.0}'
        exit 1
        ;;
    *)
        echo "mock claude: unknown MOCK_CLAUDE_MODE='$MODE' (expected happy|timeout|error)" >&2
        exit 2
        ;;
esac
