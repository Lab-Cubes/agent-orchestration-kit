# @nps-kit/agents — environment configuration
#
# Copy to .env and edit for your install. Defaults below work out of the box
# for local single-machine use.

# Where agent slot directories live (inbox/ active/ done/ blocked/ per slot).
# Default: ./agents/ inside the kit directory (works after `./bin/setup`).
NPS_AGENTS_HOME=./agents

# Where git worktrees are created for task isolation.
# Default: ./worktrees/ inside the kit directory.
NPS_WORKTREES_HOME=./worktrees

# Where dispatch cost logs are written.
NPS_LOGS_HOME=./logs
