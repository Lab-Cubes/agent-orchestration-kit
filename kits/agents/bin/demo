#!/usr/bin/env bash
# bin/demo — Token-savings demonstration.
#
# Runs a canonical research task two ways:
#   1. Naive path — orchestrator sends full context to Claude as prompt tokens
#   2. NOP path   — orchestrator sends a small intent message, worker reads
#                   context from its scope on-demand
#
# Reports NPT consumed by each path plus the delta. Real measurement on the
# adopter's machine, not hand-counted.
#
# Requires: ./bin/setup to have completed first.

set -euo pipefail

NPS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$NPS_DIR"

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'
say()   { echo -e "${GREEN}[demo]${NC} $*"; }
hi()    { echo -e "${CYAN}$*${NC}"; }
warn()  { echo -e "${YELLOW}[demo]${NC} $*"; }

if [[ ! -f .nps-installed ]]; then
    warn "This kit has not been set up yet. Run ./bin/setup first."
    exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
    warn "Claude Code CLI ('claude') not found on PATH. Install it first:"
    warn "  https://docs.anthropic.com/en/docs/claude-code"
    exit 1
fi

# ---------------------------------------------------------------------------
# The canonical demo task
#
# Both paths produce a one-paragraph summary of the same input document.
# We use this kit's own README as the document under test so the demo is
# self-contained — no external data required.
# ---------------------------------------------------------------------------

SUBJECT_FILE="$NPS_DIR/README.md"
TASK_INTENT="Summarise the document at ./README.md in exactly one paragraph. Output only the paragraph, no preamble."

if [[ ! -f "$SUBJECT_FILE" ]]; then
    # Fall back to the AGENT-CLAUDE template if README is somehow missing.
    SUBJECT_FILE="$NPS_DIR/templates/AGENT-CLAUDE.md"
fi

hi ""
hi "╭────────────────────────────────────────────────────────────╮"
hi "│  NPS NOP — Token-Savings Demonstration                      │"
hi "╰────────────────────────────────────────────────────────────╯"
hi ""
echo "Running the same task two ways and comparing NPT consumed."
echo "Task: one-paragraph summary of $(basename "$SUBJECT_FILE")"
echo ""

# ---------------------------------------------------------------------------
# PATH 1 — Naive orchestration
#
# The orchestrator inlines the full document into the prompt, so every
# input token counts against NPT. This is how agents usually pass context
# between each other today.
# ---------------------------------------------------------------------------

say "Path 1 — naive (full document inline in prompt)"

NAIVE_PROMPT="You are a summariser. Produce exactly one paragraph summarising the document below. Output only the paragraph.

DOCUMENT:

$(cat "$SUBJECT_FILE")"

naive_start=$(date +%s)
naive_output=$(claude -p "$NAIVE_PROMPT" \
    --model sonnet \
    --permission-mode dontAsk \
    --max-turns 2 \
    --output-format json 2>&1 | grep '^{' | head -1 || echo '{}')
naive_end=$(date +%s)
naive_duration=$((naive_end - naive_start))

naive_stats=$(python3 -c "
import json, sys
d = json.loads('''$naive_output''') if '''$naive_output'''.strip().startswith('{') else {}
u = d.get('usage', {}) or {}
i = u.get('input_tokens', 0) or 0
o = u.get('output_tokens', 0) or 0
c = u.get('cache_read_input_tokens', 0) or 0
npt = i + o + c
print(f'{npt}|{d.get(\"total_cost_usd\", 0):.4f}')
" 2>/dev/null || echo "0|0.0000")

naive_npt="${naive_stats%%|*}"
naive_usd="${naive_stats##*|}"
say "  Path 1 result: ${naive_npt} NPT (~\$${naive_usd}), ${naive_duration}s"

# ---------------------------------------------------------------------------
# PATH 2 — NOP dispatch
#
# The orchestrator writes a small intent message into the worker's inbox
# and launches the worker. The worker reads the document from its local
# scope — its input tokens are the intent + its CLAUDE.md bootstrap, NOT
# a duplicated copy of the document. That's where the saving lives.
# ---------------------------------------------------------------------------

echo ""
say "Path 2 — NOP dispatch (worker reads document from scope)"

# Ensure researcher-01 is clean (no leftover inbox)
./scripts/spawn-agent.sh clean researcher-01 > /dev/null 2>&1 || true

nop_start=$(date +%s)
./scripts/spawn-agent.sh dispatch researcher-01 "$TASK_INTENT" \
    --scope "$NPS_DIR" \
    --category research \
    --model sonnet \
    --max-turns 6 > /dev/null 2>&1 || true
nop_end=$(date +%s)
nop_duration=$((nop_end - nop_start))

nop_result_dir="$NPS_DIR/agents/researcher-01/done"
latest_result=$(ls -t "$nop_result_dir"/*.result.json 2>/dev/null | head -1 || echo "")

if [[ -n "$latest_result" ]]; then
    nop_npt=$(python3 -c "
import json
d = json.load(open('$latest_result'))
print(d.get('payload', {}).get('cost_npt', 0))
" 2>/dev/null || echo "0")
else
    nop_npt="0"
fi

say "  Path 2 result: ${nop_npt} NPT, ${nop_duration}s"

# ---------------------------------------------------------------------------
# Comparison
# ---------------------------------------------------------------------------

if [[ "$naive_npt" -gt 0 && "$nop_npt" -gt 0 ]]; then
    savings_pct=$(python3 -c "print(f'{(1 - $nop_npt/$naive_npt)*100:.1f}')")
else
    savings_pct="n/a"
fi

echo ""
hi "╭────────────────────────────────────────────────────────────╮"
hi "│  Result                                                     │"
hi "╰────────────────────────────────────────────────────────────╯"
printf "  Naive (prompt-embedded context):  %10s NPT\n" "$naive_npt"
printf "  NPS NOP (mailbox dispatch):       %10s NPT\n" "$nop_npt"
printf "  Savings:                          %10s%%\n" "$savings_pct"
echo ""
echo "Notes:"
echo "  • NPT is the NPS-0 §4.3 standardized token unit. This kit approximates it"
echo "    as (input + output + cache_read) tokens from Claude's JSON output;"
echo "    cross-SDK interoperability per the full token-budget.md spec lands in v0.2.0."
echo "  • Both paths used Claude Sonnet. Savings compound as context grows."
echo ""
echo "Inspect the worker's full result:"
echo "  ./scripts/spawn-agent.sh status researcher-01"
