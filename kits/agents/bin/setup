#!/usr/bin/env bash
# bin/setup — First-run kit setup.
#
# Bootstraps a fresh clone for immediate use: copies example configs if
# absent, creates runtime directories, sets up three default workers
# (coder-01, critic-01, researcher-01), installs an identity mark so
# the benchmark knows the install is complete.
#
# Safe to re-run. Won't overwrite existing configs or workers.

set -euo pipefail

NPS_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$NPS_DIR"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
say()  { echo -e "${GREEN}[setup]${NC} $*"; }
warn() { echo -e "${YELLOW}[setup]${NC} $*"; }

# 1. Configs
if [[ ! -f .env ]]; then
    cp .env.example .env
    say "Created .env from .env.example"
fi

if [[ ! -f config.json ]]; then
    cp config.example.json config.json
    say "Created config.json from config.example.json"
fi

# 2. Runtime directories
# Default to $HOME/.nps-kit/ (or $XDG_STATE_HOME/nps-kit on Linux systems
# that set XDG_STATE_HOME) so worker mailboxes live outside the kit's git
# tree. Prevents accidental commits to the kit from a worker's shell.
# Operators can override any of NPS_STATE_HOME, NPS_AGENTS_HOME,
# NPS_WORKTREES_HOME, NPS_LOGS_HOME to relocate — e.g.
# NPS_STATE_HOME="$NPS_DIR" to keep the old in-kit layout.
if [[ -n "${NPS_STATE_HOME:-}" ]]; then
    STATE_HOME="$NPS_STATE_HOME"
elif [[ -n "${XDG_STATE_HOME:-}" ]]; then
    STATE_HOME="$XDG_STATE_HOME/nps-kit"
else
    STATE_HOME="$HOME/.nps-kit"
fi
AGENTS_HOME="${NPS_AGENTS_HOME:-$STATE_HOME/agents}"
WORKTREES_HOME="${NPS_WORKTREES_HOME:-$STATE_HOME/worktrees}"
LOGS_HOME="${NPS_LOGS_HOME:-$STATE_HOME/logs}"
mkdir -p "$AGENTS_HOME" "$WORKTREES_HOME" "$LOGS_HOME"
say "Runtime directories ready:"
say "  agents    → $AGENTS_HOME"
say "  worktrees → $WORKTREES_HOME"
say "  logs      → $LOGS_HOME"

# 3. Default workers
for trio in "coder-01 coder" "critic-01 critic" "researcher-01 researcher"; do
    set -- $trio
    agent_id="$1"
    agent_type="$2"
    if [[ -d "$AGENTS_HOME/$agent_id" ]]; then
        warn "Worker $agent_id already exists — skipping"
    else
        ./scripts/spawn-agent.sh setup "$agent_id" "$agent_type" > /dev/null
        say "Worker ready: $agent_id ($agent_type)"
    fi
done

# 4. Install marker
date -u +%Y-%m-%dT%H:%M:%SZ > .nps-installed
say "Install mark written to .nps-installed"

echo ""
say "Setup complete."
echo ""
echo "Next steps:"
echo "  ./bin/benchmark                             # Run the token-savings benchmark"
echo "  ./scripts/spawn-agent.sh status coder-01    # Inspect a worker"
echo "  edit config.json                            # Customize for your org"
