{
  "name": "@nps-kit/agents",
  "version": "0.1.0",
  "description": "NOP (Neural Orchestration Protocol) reference kit — mailbox-based multi-agent orchestration per NPS-5. Wraps any AI agent runtime (reference impl uses Claude Code CLI) with a portable task-dispatch protocol.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "bin": {
    "nps-agents": "./bin/nps-agents"
  },
  "scripts": {
    "setup": "./bin/setup",
    "benchmark": "./bin/benchmark",
    "test": "pnpm run test:changed",
    "test:all": "bats tests",
    "test:changed": "bats tests/cmd_ack.bats tests/decompose.bats tests/dispatch_tasklist.bats",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "bats": "^1.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
